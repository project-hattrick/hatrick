generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Player
  Moderator
  Admin
}

enum UserStatus {
  Active
  Suspended
  Deleted
}

enum BetStatus {
  Pending
  Won
  Lost
  Void
  CashedOut
}

enum MarketType {
  MatchResult
  NextGoal
  TotalGoals
  PlayerToScore
  Corners
  Cards
}

model User {
  id            String     @id @default(cuid())
  walletAddress String     @unique
  email         String?    @unique
  displayName   String?
  avatarUrl     String?
  role          UserRole   @default(Player)
  status        UserStatus @default(Active)
  balance       Decimal    @default(1000) @db.Decimal(18, 2)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  bets Bet[]

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Bet {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixtureId Int
  market    MarketType
  selection String
  stake     Decimal    @db.Decimal(18, 2)
  oddsTaken Decimal    @db.Decimal(10, 3)
  status    BetStatus  @default(Pending)
  placedAt  DateTime   @default(now())
  settledAt DateTime?

  @@index([userId])
  @@index([fixtureId])
  @@index([status])
  @@map("bets")
}
