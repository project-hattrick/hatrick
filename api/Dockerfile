# hat-trick / api — multi-stage image for Fly.io / Render / any Docker host.
# Build and runtime share node:20-slim (Debian) so the Prisma query engine generated
# at build time matches the runtime libc/openssl — no binaryTargets juggling needed.

# ── builder ──────────────────────────────────────────────────────────────────
FROM node:20-slim AS builder
WORKDIR /app

# Prisma needs openssl to detect its engine; ca-certificates for outbound TLS (TxLINE).
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Copy the manifest + Prisma schema before install so the `postinstall` hook
# (`prisma generate`) finds the schema. Full install — the Prisma CLI (a devDependency)
# is needed at runtime for `migrate deploy`, so we keep node_modules unpruned.
COPY package.json package-lock.json ./
COPY prisma ./prisma
RUN npm ci

# Compile Nest → dist/ (client already generated by postinstall).
COPY . .
RUN npm run build

# ── runtime ──────────────────────────────────────────────────────────────────
FROM node:20-slim AS runtime
ENV NODE_ENV=production
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/package.json ./package.json

# Bind to the platform-provided port; PORT is read in src/main.ts (defaults 3001).
ENV PORT=3001
EXPOSE 3001

# Apply pending migrations on boot (idempotent) then start. Keeps Render/`docker run`
# self-sufficient; on Fly it runs once per deploy before traffic — see fly.toml.
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/main"]
