# hat-trick / api
PORT=3001

# Keep ingest off until creds are set, so the app boots cleanly.
TXLINE_ENABLED=false
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=

# Postgres (docker-compose)
POSTGRES_USER=hattrick
POSTGRES_PASSWORD=hattrick
POSTGRES_DB=hattrick
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hattrick:hattrick@localhost:5432/hattrick

# Redis (docker-compose)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Solana / chain — keep disabled until keypairs are set, so the app boots cleanly.
SOLANA_ENABLED=false
SOLANA_CLUSTER=devnet
# Defaults to the cluster URL; set to http://127.0.0.1:8899 for a local validator.
SOLANA_RPC_URL=
HAT_TRICK_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Keypairs: inline JSON secret array (e.g. [12,34,...]) OR a path to a keypair file.
# NEVER commit real secrets — .env is git-ignored.
SOLANA_MINT_AUTHORITY=
SOLANA_ORACLE=
# Play token. Leave PLAY_TOKEN_MINT empty to create one on first faucet use (dev).
PLAY_TOKEN_MINT=
PLAY_TOKEN_DECIMALS=6
FAUCET_AMOUNT=1000
