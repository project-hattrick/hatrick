# hat-trick / api
PORT=3001

# Keep ingest off until creds are set, so the app boots cleanly.
# Host = network selector: devnet -> https://txline-dev.txodds.com (pairs with the
# devnet program), mainnet -> https://txline.txodds.com. Must match the program you
# subscribed on, or /api/token/activate 504s verifying the tx on the wrong cluster.
TXLINE_ENABLED=false
TXLINE_BASE_URL=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=

# Historical replay — feed a past match through the live pipeline (POST /replay,
# or ENABLED=true to auto-run on boot). Handy when no match is live.
TXLINE_REPLAY_ENABLED=false
TXLINE_REPLAY_FIXTURE_ID=
TXLINE_REPLAY_EPOCH_DAY=
TXLINE_REPLAY_START_HOUR=
TXLINE_REPLAY_HOURS=3
TXLINE_REPLAY_SPEED=8

# Privy — Privy-token login (POST /auth/login). Get values from app.privy.io.
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
# Optional: verification key (RS256 PEM) for offline JWT verification. Leave blank to use HTTP.
PRIVY_VERIFICATION_KEY=

# Auth — wallet sign-in session JWTs. Set a long random secret in prod.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d
# Allowed browser origin(s) for CORS + the session cookie (comma-separated).
FRONT_ORIGIN=http://localhost:3000
# Session-cookie cross-site behaviour. Locally front + api are same-site → leave `lax`.
# For split-domain prod (front on Vercel, api on Fly/Render) set `none` so the browser sends
# the cookie cross-site; `none` auto-forces Secure (HTTPS only). Optional cookie domain scope
# (leave unset for host-only; only useful if front + api share a parent domain).
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# Postgres (docker-compose)
POSTGRES_USER=hattrick
POSTGRES_PASSWORD=hattrick
POSTGRES_DB=hattrick
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hattrick:hattrick@localhost:5432/hattrick

# Redis (docker-compose)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Solana / chain — keep disabled until keypairs are set, so the app boots cleanly.
SOLANA_ENABLED=false
SOLANA_CLUSTER=devnet
# Defaults to the cluster URL; set to http://127.0.0.1:8899 for a local validator.
SOLANA_RPC_URL=

# ── Program IDs ───────────────────────────────────────────────────────────────
# Each has a default (devnet addresses declared in the Anchor programs).
# Override here after a re-deploy.
HATTRICK_BETTING_PROGRAM_ID=GhGZEarksLDfSDHg98PKm2xZuHJjSE8Zujd9mBB8zqXc
HATTRICK_FANTASY_PROGRAM_ID=67QvSGTacjzuQFJujCREMWtRVonCLypqKmK2dszVdDwz
HATTRICK_PACKS_PROGRAM_ID=BtgAtofxN8RJxaC824XUeamCZL13b63u2YaVTvhVGfFo
HATTRICK_PROVABLY_FAIR_PROGRAM_ID=DsWff3P22AsnXAk7EthHNythzDWLc7bg5JS3aPpNjsLQ
MPL_CORE_PROGRAM_ID=CoreZaLvA6qNVdcbAgxdFegSKHudEQrqu6EPCfWQR9Hq
# Legacy / optional — the original single-program id (betting only). Kept for back-compat.
HAT_TRICK_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J

# ── Keypairs ──────────────────────────────────────────────────────────────────
# Inline JSON secret array (e.g. [12,34,...]) OR a path to a keypair file.
# NEVER commit real secrets — .env is git-ignored.
SOLANA_MINT_AUTHORITY=
# Oracle signer for settling betting markets.
SOLANA_ORACLE=
# Layer keypair: the sole authority for fantasy duels, pack vaults, and the
# provably-fair seed oracle. Falls back to SOLANA_MINT_AUTHORITY when unset.
SOLANA_LAYER=

# ── Mints ─────────────────────────────────────────────────────────────────────
# Play token. Leave PLAY_TOKEN_MINT empty to create one on first faucet use (dev).
PLAY_TOKEN_MINT=
PLAY_TOKEN_DECIMALS=6
# USDC mint used for fantasy-duel USDC escrow. Defaults to PLAY_TOKEN_MINT when unset.
USDC_MINT=

# ── Economics ─────────────────────────────────────────────────────────────────
FAUCET_AMOUNT=1000
# Seconds after a market's close_ts before it can be voided (refunds). Default 3h.
VOID_DELAY_SECONDS=10800
# Base URI prepended to each minted card's metadata (used by hattrick_packs fulfill_pack).
CARD_METADATA_BASE_URI=https://metadata.hattrick.app/cards/
